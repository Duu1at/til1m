<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Placeholder (no data yet) -->
    <TextView
        android:id="@+id/widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:text="Откройте TIl1m чтобы начать учить слова"
        android:textColor="#888888"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Review label -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="@drawable/widget_badge_bg"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:text="Повторение"
        android:textColor="#3730A3"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Associative image -->
    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Left content block -->
    <LinearLayout
        android:id="@+id/widget_word_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/widget_image"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#111827"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_transcription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#6B7280"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_audio_btn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="🔊"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#374151"
            android:textSize="13sp" />

        <!-- Progress bar (native ProgressBar — supports setProgress via RemoteViews) -->
        <ProgressBar
            android:id="@+id/widget_progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#E0E0E0"
            android:progressTint="#1F4E8C" />

        <TextView
            android:id="@+id/widget_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="0 из 5"
            android:textColor="#9CA3AF"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Review button -->
    <TextView
        android:id="@+id/widget_review_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:background="@drawable/widget_badge_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Повторить слова"
        android:textColor="#3730A3"
        android:textSize="10sp"
        android:visibility="gone" />

</RelativeLayout>
