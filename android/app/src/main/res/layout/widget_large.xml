<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Placeholder (no data yet) -->
    <TextView
        android:id="@+id/widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Откройте TIl1m чтобы начать учить слова"
        android:textColor="#888888"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Review label -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_badge_bg"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="Повторение"
        android:textColor="#3730A3"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Word + part of speech row (tap → open word detail) -->
    <LinearLayout
        android:id="@+id/widget_word_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_word"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_part_of_speech"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="#3730A3"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Associative image -->
    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Transcription + audio icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_transcription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_audio_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="🔊"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Translation -->
    <TextView
        android:id="@+id/widget_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#374151"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Example sentence -->
    <TextView
        android:id="@+id/widget_example"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#9CA3AF"
        android:textSize="11sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <!-- Flexible spacer: TextView is the only safe spacer in RemoteViews -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Native progress bar — reliable setProgress via RemoteViews -->
    <ProgressBar
        android:id="@+id/widget_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="#E0E0E0"
        android:progressTint="#1F4E8C" />

    <!-- Progress text + streak row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 из 5 слов"
            android:textColor="#6B7280"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 дней подряд"
            android:textColor="#D97706"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Review button -->
    <TextView
        android:id="@+id/widget_review_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_badge_bg"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:text="Повторить слова"
        android:textColor="#3730A3"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
